
# ─── Chain ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=1001
NEXT_PUBLIC_RPC_URL=https://public-en-kairos.node.kaia.io

# ─── Core protocol ─────────────────────────────────────────────────────────────
# Addresses from: forge script script/Deploy.s.sol --rpc-url kairos --broadcast
NEXT_PUBLIC_FXENGINE_ADDRESS=

# ─── Tokens ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TOKEN_MYR=
NEXT_PUBLIC_TOKEN_SGD=
NEXT_PUBLIC_TOKEN_IDRX=
NEXT_PUBLIC_TOKEN_USDT=

# ─── Pools ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POOL_MYR=
NEXT_PUBLIC_POOL_SGD=
NEXT_PUBLIC_POOL_IDRX=
NEXT_PUBLIC_POOL_USDT=

# ─── Reference only (not read by the app — kept for ops reference) ───────────
# Oracle Aggregators and Orakl feed addresses are baked into the deployed
# contracts; the frontend talks to contracts directly and does not need them.

# ─── SettlementEngine (optional, enables Intents tab) ────────────────────────
# NEXT_PUBLIC_SETTLEMENT_ENGINE_ADDRESS=

# ─── Faucet (server-side only — NEVER prefix with NEXT_PUBLIC) ───────────────
# Private key of the token owner (deployer from Deploy.s.sol).
# Enables the Faucet tab so users can mint test tokens from the UI.
# FAUCET_PRIVATE_KEY=

# ─── WalletConnect ────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
